 # Read `man 5 sway` for a complete reference.

font pando:DejaVu Sans Mono 16

gaps inner 6
gaps outer 4

# Define outer gaps (Screen margin minus inner gap to keep total spacing precise)
gaps top 14
gaps left 18
gaps right 18
gaps bottom 14

default_border pixel 2
default_floating_border pixel 2

for_window [class=".*"] border pixel 2
for_window [app_id=".*"] border pixel 2

