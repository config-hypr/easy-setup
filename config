output * bg /home/inopi/wallp/gruvbox/gruvbox_minimal_space.png fill
output * resolution 1920x1080

set $lock swaylock -f -i $HOME/wallp/gruvbox/gruvbox_minimal_space.png

exec swayidle -w \
    timeout 600 '$lock' \
    timeout 660 'swaymsg "output * dpms off"' resume 'swaymsg "output * dpms on"' \
    before-sleep '$lock'

exec /usr/lib/hyprpolkitagent/hyprpolkitagent

## keymaps

# Define programs
set $terminal        kitty
set $fileManager     "kitty yazi"
set $menu            "wofi --show drun --style ~/config/wofi/style.css --prompt 'Search' "
set $libreWolf       $HOME/Desktop/librewolf-152.0.2-1-linux-x86_64-appimage.AppImage --private-window
set $tor             $HOME/tor-browser/Browser/start-tor-browser
set $vscodium        $HOME/vscodium/codium
set $lock            "swaylock"

# Define modifier keys
set $mod             Mod4
set $alt             Mod1
set $shift           Shift

# Launch and close windows
bindsym $mod+Return          exec $terminal
bindsym $mod+$shift+Return   exec foot
bindsym $mod+q               kill
bindsym $mod+w               kill -9

# File manager and quick app launchers
bindsym $mod+e               exec $fileManager
bindsym $mod+r               exec $menu
bindsym $mod+b               exec $libreWolf
bindsym $mod+$shift+b        exec $tor
bindsym $mod+d               exec $vscodium
bindsym $mod+$shift+d        exec kitty --title vim -e nvim

# Window state toggles
bindsym $mod+f               fullscreen toggle
bindsym $mod+v               floating toggle

# Move focus with vim keys (hjkl)
bindsym $mod+h               focus left
bindsym $mod+j               focus down
bindsym $mod+k               focus up
bindsym $mod+l               focus right

# Alternative arrow keys
bindsym $mod+Left            focus left
bindsym $mod+Right           focus right
bindsym $mod+Up              focus up
bindsym $mod+Down            focus down

# Move windows (vim keys)
bindsym $mod+$shift+h        move left
bindsym $mod+$shift+j        move down
bindsym $mod+$shift+k        move up
bindsym $mod+$shift+l        move right

# Resize windows (hold and use hjkl or arrows)
mode "resize" {
    bindsym h                resize shrink width 10px
    bindsym j                resize grow height 10px
    bindsym k                resize shrink height 10px
    bindsym l                resize grow width 10px
    bindsym Left             resize shrink width 10px
    bindsym Down             resize grow height 10px
    bindsym Up               resize shrink height 10px
    bindsym Right            resize grow width 10px
    bindsym Return           mode "default"
    bindsym Escape           mode "default"
}
bindsym $mod+r               mode "resize"

# Layout toggles
bindsym $mod+j               split toggle

# Switch workspaces with $mod + [0-9]
bindsym $mod+1               workspace number 1
bindsym $mod+2               workspace number 2
bindsym $mod+3               workspace number 3
bindsym $mod+4               workspace number 4
bindsym $mod+5               workspace number 5
bindsym $mod+6               workspace number 6
bindsym $mod+7               workspace number 7
bindsym $mod+8               workspace number 8
bindsym $mod+9               workspace number 9
bindsym $mod+0               workspace number 10

# Move windows to workspaces
bindsym $mod+$shift+1        move container to workspace number 1
bindsym $mod+$shift+2        move container to workspace number 2
bindsym $mod+$shift+3        move container to workspace number 3
bindsym $mod+$shift+4        move container to workspace number 4
bindsym $mod+$shift+5        move container to workspace number 5
bindsym $mod+$shift+6        move container to workspace number 6
bindsym $mod+$shift+7        move container to workspace number 7
bindsym $mod+$shift+8        move container to workspace number 8
bindsym $mod+$shift+9        move container to workspace number 9
bindsym $mod+$shift+0        move container to workspace number 10

# Quick workspace cycling (note: Tab doesn't work well in Sway, use alternatives)
bindsym $mod+Tab             workspace next
bindsym $mod+$shift+Tab      workspace prev

# Mouse wheel workspace switching (requires extra setup - commented out by default)
# bindsym --whole-window $mod+button4   workspace next
# bindsym --whole-window $mod+button5   workspace prev

# Scratchpad toggle
bindsym $mod+s               scratchpad show
bindsym $mod+$shift+s        move scratchpad

# Alternative scratchpad
bindsym $alt+s               exec echo "Alternative scratchpad - configure as needed"

# Power and lock
bindsym $mod+p               exec $HOME/.config/sway/scripts/power.sh
bindsym $mod+$shift+l        exec $lock
bindsym $mod+m               exit
bindsym $mod+Shift+c         reload
bindsym $mod+Shift+n exec wlsunset -S 00:00 -s 00:01 -t 4999 -T 5000
bindsym $mod+Shift+o exec pkill wlsunset


# Notification center
bindsym $mod+n               exec swaync-client -t -sw

# Move/resize windows with $mod + mouse
floating_modifier $mod

# Left click drag to move
bindsym $mod+button1         exec swaymsg "floating toggle; floating enable"

# Right click drag to resize (when floating)
bindsym $mod+button3         exec swaymsg "floating toggle; floating enable"

# Volume control
bindsym XF86AudioRaiseVolume exec --no-startup-id wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec --no-startup-id wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute        exec --no-startup-id wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioMicMute     exec --no-startup-id wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

# Brightness control
bindsym XF86MonBrightnessUp   exec --no-startup-id brightnessctl -e4 -n2 set 5%+
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl -e4 -n2 set 5%-

# Media controls (requires playerctl)
bindsym XF86AudioNext        exec playerctl next
bindsym XF86AudioPause       exec playerctl play-pause
bindsym XF86AudioPlay        exec playerctl play-pause
bindsym XF86AudioPrev        exec playerctl previous

# Quick notes/todo
bindsym $mod+a               exec kitty --title scratch -e nvim ~/notes/quick.md

# Screenshots
bindsym Print                exec grim ~/Pictures/screenshot-$(date +%s).png
bindsym $shift+Print         exec grim -g "$(slurp)" ~/Pictures/screenshot-$(date +%s).png

# waybar
bar {
    swaybar_command waybar
}

include /etc/sway/config.d/*